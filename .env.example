# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/chatvid?sslmode=require"

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# Google OAuth — console.cloud.google.com
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# GitHub OAuth — github.com/settings/apps
GITHUB_CLIENT_ID="..."
GITHUB_CLIENT_SECRET="..."

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated emails that always get the admin role (no spaces)
ADMIN_EMAILS="you@example.com"

# ── Render service (Railway) ───────────────────────────────────────────────────
# URL of your Railway render server — leave empty to render locally (dev only)
RENDER_API_URL="https://your-render-server.railway.app"
# Shared secret between Next.js and the render server
RENDER_SECRET="your-random-secret-here"

# ── Cloudinary (video storage) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
